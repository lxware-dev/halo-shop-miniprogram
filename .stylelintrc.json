{
  "extends": ["stylelint-config-standard-scss", "stylelint-config-html/vue"],
  "rules": {
    "selector-class-pattern": null,
    "no-descending-specificity": null,
    "scss/at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": ["unocss", "apply", "variants", "responsive", "screen"]
      }
    ],
    "at-rule-no-unknown": [
      true,
      {
        "ignoreAtRules": ["unocss", "apply", "variants", "responsive", "screen"]
      }
    ]
  }
}
